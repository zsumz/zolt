#!/usr/bin/env bash
set -euo pipefail

SUMMARY_FILE="target/benchmarks/competitors/summary.json"
OUTPUT_FILE=""
LANE_ID="generated-workspace"
LANE_NAME="Generated Java workspace"
LANE_KIND="generated"
ARTIFACT_NAME=""

usage() {
  cat <<'USAGE'
Usage: scripts/benchmark-suite-summary [options]

Creates suite-summary.json from a benchmark lane summary.

Options:
  --summary FILE       Lane summary JSON. Default: target/benchmarks/competitors/summary.json.
  --output FILE        Suite summary JSON. Default: directory containing SUMMARY_FILE/suite-summary.json.
  --lane-id ID         Lane id. Default: generated-workspace.
  --lane-name NAME     Lane display name. Default: Generated Java workspace.
  --lane-kind KIND     Lane kind. Default: generated.
  --artifact-name NAME Uploaded artifact name recorded in the suite summary.
  -h, --help           Show this help.
USAGE
}

fail() {
  printf 'error: %s\n' "$1" >&2
  exit 1
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --summary)
      [[ "$#" -ge 2 ]] || fail "--summary requires a value"
      SUMMARY_FILE="$2"
      shift 2
      ;;
    --output)
      [[ "$#" -ge 2 ]] || fail "--output requires a value"
      OUTPUT_FILE="$2"
      shift 2
      ;;
    --lane-id)
      [[ "$#" -ge 2 ]] || fail "--lane-id requires a value"
      LANE_ID="$2"
      shift 2
      ;;
    --lane-name)
      [[ "$#" -ge 2 ]] || fail "--lane-name requires a value"
      LANE_NAME="$2"
      shift 2
      ;;
    --lane-kind)
      [[ "$#" -ge 2 ]] || fail "--lane-kind requires a value"
      LANE_KIND="$2"
      shift 2
      ;;
    --artifact-name)
      [[ "$#" -ge 2 ]] || fail "--artifact-name requires a value"
      ARTIFACT_NAME="$2"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option '$1'"
      ;;
  esac
done

[[ -f "$SUMMARY_FILE" ]] || fail "summary file not found: $SUMMARY_FILE"
if [[ -z "$OUTPUT_FILE" ]]; then
  OUTPUT_FILE="$(dirname "$SUMMARY_FILE")/suite-summary.json"
fi
mkdir -p "$(dirname "$OUTPUT_FILE")"

python3 - "$SUMMARY_FILE" "$OUTPUT_FILE" "$LANE_ID" "$LANE_NAME" "$LANE_KIND" "$ARTIFACT_NAME" <<'PY'
import json
import os
import pathlib
import sys
from datetime import datetime, timezone

summary_path = pathlib.Path(sys.argv[1])
output_path = pathlib.Path(sys.argv[2])
lane_id = sys.argv[3]
lane_name = sys.argv[4]
lane_kind = sys.argv[5]
artifact_name = sys.argv[6]
summary = json.loads(summary_path.read_text(encoding="utf-8"))

workflow_labels = {
    "setup": "Zolt dependency setup",
    "setup-warm-build": "First clean build",
    "no-op-build": "Warm no-op build",
    "leaf-change-build": "Leaf source change",
    "root-change-build": "Root library change",
}
workflow_order = [
    "setup-warm-build",
    "no-op-build",
    "leaf-change-build",
    "root-change-build",
    "setup",
]
repeated_workflows = {
    "no-op-build",
    "leaf-change-build",
    "root-change-build",
}
tool_labels = {
    "zolt": "Zolt",
    "maven": "Maven",
    "gradle-no-daemon": "Gradle (no daemon)",
    "gradle-daemon": "Gradle (daemon)",
}
tool_order = ["zolt", "maven", "gradle-no-daemon", "gradle-daemon"]


def sort_key(row):
    workflow = row.get("workflow", "")
    if workflow in workflow_order:
        return (workflow_order.index(workflow), workflow)
    return (len(workflow_order), workflow)


def first_version_line(environment, tool):
    info = (environment.get("tools") or {}).get(tool)
    if not info:
        return "not found"
    if info.get("error"):
        return info["error"]
    if info.get("exitCode") not in (0, None):
        return f"exit {info.get('exitCode')}"
    for line in info.get("stdout", []):
        stripped = line.strip()
        if stripped and set(stripped) == {"-"}:
            continue
        if stripped:
            return stripped
    return "version output empty"


def classify(environment, workflows):
    module_count = int(environment.get("moduleCount") or 0)
    repeat_count = int(environment.get("repeatCount") or 0)
    comparable = [
        row
        for row in workflows
        if row.get("workflow") != "setup"
        and "zolt" in row.get("tools", {})
        and (
            "maven" in row.get("tools", {})
            or "gradle-no-daemon" in row.get("tools", {})
        )
    ]
    has_production_competitors = bool(comparable) and all(
        "maven" in row.get("tools", {})
        and "gradle-no-daemon" in row.get("tools", {})
        and "gradle-daemon" in row.get("tools", {})
        for row in comparable
    )
    if module_count < 20 or repeat_count < 3:
        return "Smoke validation"
    if module_count >= 40 and repeat_count >= 5 and has_production_competitors:
        return "Production-grade generated evidence"
    return "Exploratory benchmark"


def display_path(path):
    if not path:
        return None
    resolved = pathlib.Path(path).resolve()
    try:
        return str(resolved.relative_to(pathlib.Path.cwd()))
    except ValueError:
        return str(resolved)


environment = summary.get("environment") or {}
source_workflows = sorted(summary.get("workflows", []), key=sort_key)
classification = classify(environment, source_workflows)
workflow_records = []
zolt_repeated_wins = 0
repeated_count = 0
comparable_count = 0

for row in source_workflows:
    workflow = row.get("workflow")
    tools = row.get("tools") or {}
    ordered_tools = {
        tool: tools[tool]
        for tool in tool_order
        if tool in tools
    }
    for tool, metrics in tools.items():
        if tool not in ordered_tools:
            ordered_tools[tool] = metrics
    medians = {
        tool: metrics.get("medianMillis")
        for tool, metrics in ordered_tools.items()
        if isinstance(metrics.get("medianMillis"), (int, float))
    }
    winner = min(medians, key=medians.get) if medians else None
    zolt_median = medians.get("zolt")
    ratios = {}
    if zolt_median:
        for tool, median in medians.items():
            if tool != "zolt":
                ratios[tool] = median / zolt_median
    kind = "setup" if workflow in {"setup", "setup-warm-build"} else "repeated"
    if workflow in repeated_workflows:
        repeated_count += 1
        if winner == "zolt":
            zolt_repeated_wins += 1
    if "zolt" in tools and len(tools) > 1:
        comparable_count += 1
    workflow_records.append({
        "id": workflow,
        "label": workflow_labels.get(workflow, workflow),
        "kind": kind,
        "winner": winner,
        "tools": ordered_tools,
        "ratiosVsZolt": ratios,
    })

caveats = [
    "First clean build is a single setup sample; steady-state claims should use repeated workflows.",
]
if classification != "Production-grade generated evidence":
    article = "an" if classification[:1].lower() in {"a", "e", "i", "o", "u"} else "a"
    caveats.append(f"This is {article} {classification.lower()} run, not production-grade evidence.")
available_tools = {
    tool
    for row in source_workflows
    for tool in (row.get("tools") or {})
}
for required_tool, label in [
    ("maven", "Maven"),
    ("gradle-no-daemon", "Gradle no-daemon"),
    ("gradle-daemon", "Gradle daemon"),
]:
    if required_tool not in available_tools:
        caveats.append(f"{label} results are missing from at least one core comparison.")

run_url = None
if os.environ.get("GITHUB_SERVER_URL") and os.environ.get("GITHUB_REPOSITORY") and os.environ.get("GITHUB_RUN_ID"):
    run_url = (
        f"{os.environ['GITHUB_SERVER_URL']}/"
        f"{os.environ['GITHUB_REPOSITORY']}/actions/runs/"
        f"{os.environ['GITHUB_RUN_ID']}"
    )

suite = {
    "schemaVersion": 1,
    "createdAt": datetime.now(timezone.utc).isoformat(),
    "suite": {
        "name": "zolt-native-benchmarks",
        "mode": "generated-workspace",
    },
    "repository": {
        "name": os.environ.get("GITHUB_REPOSITORY"),
        "ref": os.environ.get("GITHUB_REF_NAME"),
        "commit": os.environ.get("GITHUB_SHA"),
        "runId": os.environ.get("GITHUB_RUN_ID"),
        "runUrl": run_url,
    },
    "run": {
        "classification": classification,
        "zoltSource": os.environ.get("BENCHMARK_ZOLT_SOURCE"),
        "releaseChannel": os.environ.get("BENCHMARK_RELEASE_CHANNEL"),
        "releaseVersion": os.environ.get("BENCHMARK_RELEASE_VERSION") or None,
        "gradleDaemonIncluded": os.environ.get("BENCHMARK_INCLUDE_GRADLE_DAEMON") == "true",
        "artifactName": artifact_name or None,
    },
    "lanes": [
        {
            "id": lane_id,
            "name": lane_name,
            "kind": lane_kind,
            "status": "complete",
            "workload": {
                "moduleCount": environment.get("moduleCount"),
                "appModules": 1,
                "repeatCount": environment.get("repeatCount"),
            },
            "environment": environment,
            "tools": {
                "zolt": first_version_line(environment, "zolt"),
                "maven": first_version_line(environment, "maven"),
                "gradle": first_version_line(environment, "gradle"),
            },
            "summary": {
                "classification": classification,
                "zoltFastestRepeatedWorkflows": zolt_repeated_wins,
                "repeatedWorkflowCount": repeated_count,
                "comparableWorkflowCount": comparable_count,
                "firstCleanBuildSeparated": True,
            },
            "workflows": workflow_records,
            "caveats": caveats,
            "artifacts": {
                "summaryJson": display_path(summary_path),
                "samplesJsonl": display_path(summary_path.with_name("samples.jsonl")),
                "reportMarkdown": display_path(summary_path.with_name("report.md")),
                "logsDirectory": display_path(summary_path.with_name("logs")),
            },
        }
    ],
}

output_path.write_text(json.dumps(suite, indent=2) + "\n", encoding="utf-8")
PY

printf 'wrote suite summary: %s\n' "$OUTPUT_FILE"
