#!/usr/bin/env bash
set -euo pipefail

INPUT_FILE="target/benchmarks/competitors/suite-summary.json"
OUTPUT_JSON=""
OUTPUT_MARKDOWN=""
MODEL="${OPENAI_MODEL:-gpt-5.5}"
REASONING_EFFORT="${OPENAI_REASONING_EFFORT:-high}"
DRY_RUN=false

usage() {
  cat <<'USAGE'
Usage: scripts/benchmark-openai-summary [options]

Creates an optional model-generated benchmark summary from suite-summary.json.
Requires OPENAI_API_KEY unless --dry-run is used.

Options:
  --input FILE              Suite summary JSON. Default: target/benchmarks/competitors/suite-summary.json.
  --output-json FILE        Structured model summary JSON. Default: INPUT directory/summary-ai.json.
  --output-markdown FILE    Markdown model summary. Default: INPUT directory/summary-ai.md.
  --model MODEL             OpenAI model. Default: OPENAI_MODEL or gpt-5.5.
  --reasoning-effort VALUE  Reasoning effort. Default: OPENAI_REASONING_EFFORT or high.
  --dry-run                 Write request JSON without calling the API.
  -h, --help                Show this help.
USAGE
}

fail() {
  printf 'error: %s\n' "$1" >&2
  exit 1
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --input)
      [[ "$#" -ge 2 ]] || fail "--input requires a value"
      INPUT_FILE="$2"
      shift 2
      ;;
    --output-json)
      [[ "$#" -ge 2 ]] || fail "--output-json requires a value"
      OUTPUT_JSON="$2"
      shift 2
      ;;
    --output-markdown)
      [[ "$#" -ge 2 ]] || fail "--output-markdown requires a value"
      OUTPUT_MARKDOWN="$2"
      shift 2
      ;;
    --model)
      [[ "$#" -ge 2 ]] || fail "--model requires a value"
      MODEL="$2"
      shift 2
      ;;
    --reasoning-effort)
      [[ "$#" -ge 2 ]] || fail "--reasoning-effort requires a value"
      REASONING_EFFORT="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option '$1'"
      ;;
  esac
done

[[ -f "$INPUT_FILE" ]] || fail "input file not found: $INPUT_FILE"
if [[ -z "$OUTPUT_JSON" ]]; then
  OUTPUT_JSON="$(dirname "$INPUT_FILE")/summary-ai.json"
fi
if [[ -z "$OUTPUT_MARKDOWN" ]]; then
  OUTPUT_MARKDOWN="$(dirname "$INPUT_FILE")/summary-ai.md"
fi
mkdir -p "$(dirname "$OUTPUT_JSON")" "$(dirname "$OUTPUT_MARKDOWN")"

if [[ "$DRY_RUN" == false && -z "${OPENAI_API_KEY:-}" ]]; then
  fail "OPENAI_API_KEY is required unless --dry-run is used"
fi

python3 - "$INPUT_FILE" "$OUTPUT_JSON" "$OUTPUT_MARKDOWN" "$MODEL" "$REASONING_EFFORT" "$DRY_RUN" <<'PY'
import json
import os
import pathlib
import sys
import urllib.error
import urllib.request
from datetime import datetime, timezone

input_path = pathlib.Path(sys.argv[1])
output_json_path = pathlib.Path(sys.argv[2])
output_markdown_path = pathlib.Path(sys.argv[3])
model = sys.argv[4]
reasoning_effort = sys.argv[5]
dry_run = sys.argv[6] == "true"
suite = json.loads(input_path.read_text(encoding="utf-8"))
prompt_version = "zolt-benchmark-summary-v3"

model_input = {
    "schemaVersion": suite.get("schemaVersion"),
    "suite": suite.get("suite"),
    "repository": suite.get("repository"),
    "run": suite.get("run"),
    "lanes": [
        {
            "id": lane.get("id"),
            "name": lane.get("name"),
            "kind": lane.get("kind"),
            "status": lane.get("status"),
            "workload": lane.get("workload"),
            "tools": lane.get("tools"),
            "summary": lane.get("summary"),
            "workflows": lane.get("workflows"),
            "caveats": lane.get("caveats"),
        }
        for lane in suite.get("lanes", [])
    ],
}

schema = {
    "type": "object",
    "additionalProperties": False,
    "properties": {
        "headline": {"type": "string"},
        "whatRan": {"type": "string"},
        "bottomLine": {"type": "string"},
        "resultBullets": {
            "type": "array",
            "items": {"type": "string"},
        },
        "methodologyNotes": {
            "type": "array",
            "items": {"type": "string"},
        },
        "limitations": {
            "type": "array",
            "items": {"type": "string"},
        },
    },
    "required": [
        "headline",
        "whatRan",
        "bottomLine",
        "resultBullets",
        "methodologyNotes",
        "limitations",
    ],
}

system_prompt = (
    "You write plain-English benchmark summaries for Zolt, a native Java build "
    "tool. Use only the supplied suite JSON. Make the summary glanceable: a "
    "reader should immediately understand what was measured and what the "
    "results say. Do not use the labels 'evidence grade', 'publishable claims', "
    "'lane', or 'generated workflow' in the prose. Describe the workload as a "
    "generated Java workspace with its module count, app count, repeat count, "
    "tools, and source of Zolt. Keep first clean build separate from repeated "
    "workflows. Mention missing competitors only when the supplied workflows "
    "are actually missing them. Do not write follow-ups, recommendations, next "
    "steps, roadmap items, or backlog prose. Be concise and concrete."
)
user_prompt = (
    "Create a concise benchmark brief from this suite-summary.json. Write it "
    "like: what ran, here's what the results say, and what to keep in mind. "
    "Put the most important measured outcomes in resultBullets with exact "
    "numbers and ratios when useful. Keep limitations strictly about the "
    "current methodology. "
    "Return only the structured JSON required by the schema.\n\n"
    + json.dumps(model_input, indent=2)
)
request_payload = {
    "model": model,
    "input": [
        {
            "role": "system",
            "content": [{"type": "input_text", "text": system_prompt}],
        },
        {
            "role": "user",
            "content": [{"type": "input_text", "text": user_prompt}],
        },
    ],
    "reasoning": {"effort": reasoning_effort},
    "text": {
        "verbosity": "low",
        "format": {
            "type": "json_schema",
            "name": "zolt_benchmark_summary",
            "strict": True,
            "schema": schema,
        },
    },
}

request_path = output_json_path.with_name("summary-ai-request.json")
request_path.write_text(json.dumps({
    "promptVersion": prompt_version,
    "model": model,
    "reasoningEffort": reasoning_effort,
    "request": request_payload,
}, indent=2) + "\n", encoding="utf-8")

if dry_run:
    print(f"wrote OpenAI summary request: {request_path}")
    raise SystemExit(0)

api_key = os.environ["OPENAI_API_KEY"]
request = urllib.request.Request(
    "https://api.openai.com/v1/responses",
    data=json.dumps(request_payload).encode("utf-8"),
    headers={
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    },
    method="POST",
)
try:
    with urllib.request.urlopen(request, timeout=120) as response:
        response_body = response.read().decode("utf-8")
except urllib.error.HTTPError as exc:
    body = exc.read().decode("utf-8", errors="replace")
    raise SystemExit(f"OpenAI request failed: HTTP {exc.code}: {body}") from exc

raw_response = json.loads(response_body)
output_text = raw_response.get("output_text")
if not output_text:
    chunks = []
    for item in raw_response.get("output", []):
        for content in item.get("content", []):
            if content.get("type") in {"output_text", "text"} and content.get("text"):
                chunks.append(content["text"])
    output_text = "\n".join(chunks)
if not output_text:
    raise SystemExit("OpenAI response did not contain output text")

try:
    model_summary = json.loads(output_text)
except json.JSONDecodeError as exc:
    raise SystemExit(f"OpenAI response was not valid JSON: {exc}") from exc

document = {
    "schemaVersion": 1,
    "createdAt": datetime.now(timezone.utc).isoformat(),
    "promptVersion": prompt_version,
    "model": model,
    "reasoningEffort": reasoning_effort,
    "responseId": raw_response.get("id"),
    "summary": model_summary,
}
output_json_path.write_text(json.dumps(document, indent=2) + "\n", encoding="utf-8")

workflow_labels = {
    "setup-warm-build": "First clean build",
    "no-op-build": "Warm no-op",
    "leaf-change-build": "Leaf source change",
    "root-change-build": "Root library change",
}
workflow_order = [
    "setup-warm-build",
    "no-op-build",
    "leaf-change-build",
    "root-change-build",
]
tool_labels = {
    "zolt": "Zolt",
    "maven": "Maven",
    "gradle-no-daemon": "Gradle no-daemon",
    "gradle-daemon": "Gradle daemon",
}
tool_order = ["zolt", "maven", "gradle-no-daemon", "gradle-daemon"]


def fmt_ms(value):
    if not isinstance(value, (int, float)):
        return "n/a"
    return f"{int(value):,} ms"


def workflow_sort_key(workflow):
    workflow_id = workflow.get("id")
    if workflow_id in workflow_order:
        return (workflow_order.index(workflow_id), workflow_id)
    return (len(workflow_order), workflow_id or "")


def result_table_rows(suite_document):
    rows = []
    for lane in suite_document.get("lanes", []):
        for workflow in sorted(lane.get("workflows", []), key=workflow_sort_key):
            workflow_id = workflow.get("id")
            if workflow_id not in workflow_labels:
                continue
            tools = workflow.get("tools") or {}
            if len(tools) <= 1:
                continue
            winner = workflow.get("winner")
            cells = [
                workflow_labels[workflow_id],
                tool_labels.get(winner, winner or "n/a"),
            ]
            for tool in tool_order:
                cells.append(fmt_ms((tools.get(tool) or {}).get("medianMillis")))
            rows.append(cells)
    return rows


lines = [
    "## Benchmark Summary",
    "",
    f"**{model_summary['headline']}**",
    "",
    model_summary["whatRan"],
    "",
    model_summary["bottomLine"],
    "",
    "### What The Results Say",
    "",
]
lines.extend(f"- {bullet}" for bullet in model_summary["resultBullets"])
lines.append("")
table_rows = result_table_rows(suite)
if table_rows:
    lines.extend([
        "### Results",
        "",
        "| Workflow | Winner | Zolt | Maven | Gradle no-daemon | Gradle daemon |",
        "| --- | --- | ---: | ---: | ---: | ---: |",
    ])
    lines.extend("| " + " | ".join(row) + " |" for row in table_rows)
    lines.append("")
notes = model_summary["methodologyNotes"] + model_summary["limitations"]
if notes:
    lines.extend(["### Notes", ""])
    lines.extend(f"- {note}" for note in notes)
    lines.append("")
output_markdown_path.write_text("\n".join(lines), encoding="utf-8")
print(f"wrote OpenAI summary JSON: {output_json_path}")
print(f"wrote OpenAI summary Markdown: {output_markdown_path}")
PY
