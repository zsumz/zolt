#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

PROJECT_MANIFEST="docs/benchmarks/projects.json"
PROJECT_ID=""
WORK_DIR="target/benchmarks/competitors/real-projects"
CACHE_DIR=""
REPEAT_COUNT=3
ZOLT_BIN="${ZOLT_BENCH_ZOLT:-}"
MAVEN_BIN="${ZOLT_BENCH_MAVEN:-}"
GRADLE_BIN="${ZOLT_BENCH_GRADLE:-}"
SAMPLE_TIMEOUT_SECONDS=1800
DRY_RUN=false

usage() {
  cat <<'USAGE'
Usage: scripts/benchmark-real-project [options]

Runs a pinned same-source Zolt, Maven, and Gradle comparison.

Options:
  --project ID             Project id from docs/benchmarks/projects.json.
  --project-manifest FILE  Project manifest. Default: docs/benchmarks/projects.json.
  --work-dir DIR           Output directory. Default: target/benchmarks/competitors/real-projects.
  --cache-dir DIR          Shared dependency cache directory. Default: WORK_DIR/caches.
  --repeat COUNT           Timed samples for repeated workflows. Default: 3.
  --zolt PATH              Zolt executable. Default: ZOLT_BENCH_ZOLT or zolt on PATH.
  --maven PATH             Maven executable. Default: mvn on PATH.
  --gradle PATH            Gradle executable. Default: gradle on PATH.
  --sample-timeout SECONDS Per-command timeout. Default: 1800.
  --dry-run                Validate the lane and write planned outputs without cloning or timing.
  -h, --help               Show this help.

Each checked-in adapter copies one explicit upstream source set into isolated
Zolt, Maven, Gradle no-daemon, and Gradle daemon overlays. Dependency caches are
warmed before timing. The measured workflows are a clean compile, a warm no-op
compile, and an incremental source change. Adapter omissions remain part of
every result artifact.
USAGE
}

fail() {
  printf 'error: %s\n' "$1" >&2
  exit 1
}

positive_int() {
  [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

abs_path() {
  case "$1" in
    "") printf '\n' ;;
    /*) printf '%s\n' "$1" ;;
    *) printf '%s\n' "$ROOT/$1" ;;
  esac
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --project)
      [[ "$#" -ge 2 ]] || fail "--project requires a value"
      PROJECT_ID="$2"
      shift 2
      ;;
    --project-manifest)
      [[ "$#" -ge 2 ]] || fail "--project-manifest requires a value"
      PROJECT_MANIFEST="$2"
      shift 2
      ;;
    --work-dir)
      [[ "$#" -ge 2 ]] || fail "--work-dir requires a value"
      WORK_DIR="$2"
      shift 2
      ;;
    --cache-dir)
      [[ "$#" -ge 2 ]] || fail "--cache-dir requires a value"
      CACHE_DIR="$2"
      shift 2
      ;;
    --repeat)
      [[ "$#" -ge 2 ]] || fail "--repeat requires a value"
      positive_int "$2" || fail "--repeat requires a positive integer"
      REPEAT_COUNT="$2"
      shift 2
      ;;
    --zolt)
      [[ "$#" -ge 2 ]] || fail "--zolt requires a value"
      ZOLT_BIN="$2"
      shift 2
      ;;
    --maven)
      [[ "$#" -ge 2 ]] || fail "--maven requires a value"
      MAVEN_BIN="$2"
      shift 2
      ;;
    --gradle)
      [[ "$#" -ge 2 ]] || fail "--gradle requires a value"
      GRADLE_BIN="$2"
      shift 2
      ;;
    --sample-timeout)
      [[ "$#" -ge 2 ]] || fail "--sample-timeout requires a value"
      positive_int "$2" || fail "--sample-timeout requires a positive integer"
      SAMPLE_TIMEOUT_SECONDS="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option '$1'"
      ;;
  esac
done

[[ -n "$PROJECT_ID" ]] || fail "--project is required"
case "$WORK_DIR" in
  "" | "." | "/" | "$ROOT") fail "refusing unsafe benchmark work directory: $WORK_DIR" ;;
esac

PROJECT_MANIFEST="$(abs_path "$PROJECT_MANIFEST")"
WORK_DIR="$(abs_path "$WORK_DIR")"
if [[ -z "$CACHE_DIR" ]]; then
  CACHE_DIR="$WORK_DIR/caches"
else
  CACHE_DIR="$(abs_path "$CACHE_DIR")"
fi
mkdir -p "$WORK_DIR"

python3 - "$ROOT" "$PROJECT_MANIFEST" "$PROJECT_ID" "$WORK_DIR" "$CACHE_DIR" "$REPEAT_COUNT" "$ZOLT_BIN" "$MAVEN_BIN" "$GRADLE_BIN" "$SAMPLE_TIMEOUT_SECONDS" "$DRY_RUN" <<'PY'
import html
import json
import os
import pathlib
import platform
import shutil
import statistics
import subprocess
import sys
import time
from datetime import datetime, timezone

repo_root = pathlib.Path(sys.argv[1])
manifest_path = pathlib.Path(sys.argv[2])
project_id = sys.argv[3]
work_dir = pathlib.Path(sys.argv[4])
cache_dir = pathlib.Path(sys.argv[5])
repeat_count = int(sys.argv[6])
explicit_zolt = sys.argv[7] or None
explicit_maven = sys.argv[8] or None
explicit_gradle = sys.argv[9] or None
sample_timeout_seconds = int(sys.argv[10])
dry_run = sys.argv[11] == "true"

if not manifest_path.is_file():
    raise SystemExit(f"project manifest not found: {manifest_path}")

manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
project = next((item for item in manifest.get("projects", []) if item.get("id") == project_id), None)
if not project:
    raise SystemExit(f"project not found in manifest: {project_id}")
if project.get("status") != "comparison-ready":
    raise SystemExit(f"project {project_id} is not comparison-ready")

pin = project.get("pin") or {}
pin_value = pin.get("value")
if not pin_value:
    raise SystemExit(f"project {project_id} does not have an immutable pin")

native_tool = project.get("nativeTool")
if native_tool not in {"maven", "gradle"}:
    raise SystemExit(f"unsupported upstream tool for {project_id}: {native_tool}")

adapter_path = pathlib.Path(project.get("adapterPath") or "")
if not adapter_path.is_absolute():
    adapter_path = repo_root / adapter_path
if not adapter_path.is_file():
    raise SystemExit(f"adapter coverage file not found: {adapter_path}")
coverage = json.loads(adapter_path.read_text(encoding="utf-8"))
if coverage.get("projectId") != project_id or coverage.get("status") != "comparison-ready":
    raise SystemExit(f"adapter coverage is not comparison-ready for {project_id}")
if ((coverage.get("upstream") or {}).get("commit")) != pin_value:
    raise SystemExit(f"adapter pin does not match manifest pin for {project_id}")
adapter = coverage.get("adapter") or {}
if adapter.get("type") != "generated-same-source-overlay":
    raise SystemExit(f"unsupported adapter type for {project_id}: {adapter.get('type')}")

source_roots = adapter.get("sourceRoots") or []
if not source_roots:
    raise SystemExit(f"adapter {project_id} has no source roots")
source_change_target = adapter.get("sourceChangeTarget")
if not source_change_target:
    raise SystemExit(f"adapter {project_id} has no source-change target")

work_dir.mkdir(parents=True, exist_ok=True)
checkout_dir = work_dir / "checkout"
logs_dir = work_dir / "logs"
projects_dir = work_dir / "projects"
zolt_project = projects_dir / "zolt"
maven_project = projects_dir / "maven"
gradle_no_daemon_project = projects_dir / "gradle-no-daemon"
gradle_daemon_project = projects_dir / "gradle-daemon"
tool_ids = ("zolt", "maven", "gradle-no-daemon", "gradle-daemon")
logs_dir.mkdir(parents=True, exist_ok=True)
samples_path = work_dir / "samples.jsonl"
summary_path = work_dir / "summary.json"
suite_path = work_dir / "suite-summary.json"
report_path = work_dir / "report.md"


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def resolve_tool(explicit, fallback):
    if explicit:
        if "/" in explicit:
            return str(pathlib.Path(explicit).resolve())
        return explicit
    return shutil.which(fallback) or fallback


tool_paths = {
    "zolt": resolve_tool(explicit_zolt, "zolt"),
    "maven": resolve_tool(explicit_maven, "mvn"),
    "gradle": resolve_tool(explicit_gradle, "gradle"),
}


def rel(path):
    try:
        return str(path.resolve().relative_to(repo_root))
    except ValueError:
        return str(path.resolve())


def run_process(command, cwd, log_name, timeout_seconds=None):
    log_path = logs_dir / log_name
    log_path.parent.mkdir(parents=True, exist_ok=True)
    started_at = now_iso()
    start = time.perf_counter_ns()
    timed_out = False
    with log_path.open("w", encoding="utf-8") as log:
        log.write("$ " + " ".join(command) + "\n\n")
        try:
            process = subprocess.run(
                command,
                cwd=str(cwd),
                stdout=log,
                stderr=subprocess.STDOUT,
                text=True,
                check=False,
                timeout=timeout_seconds,
            )
            exit_code = process.returncode
        except subprocess.TimeoutExpired:
            timed_out = True
            exit_code = 124
            log.write(f"\nCommand timed out after {timeout_seconds} seconds.\n")
        except FileNotFoundError as exc:
            exit_code = 127
            log.write(f"\n{exc}\n")
    return {
        "command": command,
        "exitCode": exit_code,
        "durationMillis": round((time.perf_counter_ns() - start) / 1_000_000),
        "timedOut": timed_out,
        "startedAt": started_at,
        "finishedAt": now_iso(),
        "log": rel(log_path),
    }


def checked(command, cwd, log_name):
    result = run_process(command, cwd, log_name, sample_timeout_seconds)
    if result["exitCode"] != 0:
        raise RuntimeError(f"command failed ({result['exitCode']}): {' '.join(command)}; log: {result['log']}")
    return result


def capture_tool(command):
    try:
        process = subprocess.run(
            command,
            cwd=str(work_dir),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            check=False,
            timeout=30,
        )
        return {"command": command, "exitCode": process.returncode, "stdout": process.stdout.splitlines()[:20]}
    except (FileNotFoundError, subprocess.TimeoutExpired) as exc:
        return {"command": command, "exitCode": None, "error": str(exc), "stdout": []}


def prepare_checkout():
    if checkout_dir.exists() and not (checkout_dir / ".git").is_dir():
        raise RuntimeError(f"checkout path exists but is not a git repository: {checkout_dir}")
    if not checkout_dir.exists():
        checkout_dir.mkdir(parents=True)
        checked(["git", "init"], checkout_dir, "checkout/001-git-init.log")
        checked(["git", "remote", "add", "origin", project["upstreamUrl"]], checkout_dir, "checkout/002-git-remote-add.log")
    else:
        checked(["git", "remote", "set-url", "origin", project["upstreamUrl"]], checkout_dir, "checkout/002-git-remote-set-url.log")
    checked(["git", "fetch", "--depth", "1", "origin", pin_value], checkout_dir, "checkout/003-git-fetch.log")
    checked(["git", "checkout", "--detach", "FETCH_HEAD"], checkout_dir, "checkout/004-git-checkout.log")
    checked(["git", "reset", "--hard", pin_value], checkout_dir, "checkout/005-git-reset.log")
    checked(["git", "clean", "-ffdx"], checkout_dir, "checkout/006-git-clean.log")


def copy_root(row, destination):
    source = checkout_dir / row["from"]
    if not source.exists():
        if row.get("optional"):
            return
        raise RuntimeError(f"adapter source root does not exist: {row['from']}")
    target = destination / row["to"]
    if source.is_dir():
        shutil.copytree(source, target, dirs_exist_ok=True)
    else:
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)


def prepare_overlays():
    if projects_dir.exists():
        shutil.rmtree(projects_dir)
    destinations = (zolt_project, maven_project, gradle_no_daemon_project, gradle_daemon_project)
    for destination in destinations:
        destination.mkdir(parents=True)
        for row in source_roots:
            copy_root(row, destination)
        for row in adapter.get("resourceRoots") or []:
            copy_root(row, destination)
        for excluded in adapter.get("excludes") or []:
            target = destination / excluded
            if target.is_dir():
                shutil.rmtree(target)
            elif target.exists():
                target.unlink()
        changed = destination / source_change_target
        if not changed.is_file():
            raise RuntimeError(f"source-change target is missing from overlay: {source_change_target}")
    source_count = len(list(zolt_project.glob("**/*.java")))
    if source_count == 0:
        raise RuntimeError(f"adapter {project_id} copied no Java sources")
    write_zolt_config()
    write_maven_config(maven_project)
    write_gradle_config(gradle_no_daemon_project)
    write_gradle_config(gradle_daemon_project)
    return source_count, sum(
        len(path.read_text(encoding="utf-8", errors="replace").splitlines())
        for path in zolt_project.glob("**/*.java")
    )


def toml_string(value):
    return json.dumps(str(value))


def write_zolt_config():
    lines = [
        "[project]",
        f"name = {toml_string(adapter['name'])}",
        f"version = {toml_string(adapter['version'])}",
        f"group = {toml_string(adapter['group'])}",
        f"java = {toml_string(adapter.get('java') or '21')}",
        "",
        "[repositories]",
        'central = "https://repo.maven.apache.org/maven2"',
    ]
    platforms = adapter.get("platforms") or {}
    if platforms:
        lines.extend(["", "[platforms]"])
        lines.extend(f"{toml_string(key)} = {toml_string(value)}" for key, value in sorted(platforms.items()))
    lines.extend(["", "[dependencies]"])
    for key, value in sorted((adapter.get("dependencies") or {}).items()):
        rendered = "{}" if value is None else toml_string(value)
        lines.append(f"{toml_string(key)} = {rendered}")
    provided = adapter.get("providedDependencies") or {}
    if provided:
        lines.extend(["", "[provided.dependencies]"])
        lines.extend(f"{toml_string(key)} = {toml_string(value)}" for key, value in sorted(provided.items()))
    lines.extend([
        "",
        "[build]",
        'source = "src/main/java"',
        'test = "src/test/java"',
        'output = "target/classes"',
        'testOutput = "target/test-classes"',
        "",
        "[compiler]",
        f"release = {toml_string(adapter['compilerRelease'])}",
        'encoding = "UTF-8"',
    ])
    resource_paths = sorted({row["to"] for row in adapter.get("resourceRoots") or [] if (zolt_project / row["to"]).exists()})
    if resource_paths:
        lines.extend(["", "[resources]", "main = [" + ", ".join(toml_string(path) for path in resource_paths) + "]"])
    (zolt_project / "src/test/java").mkdir(parents=True, exist_ok=True)
    (zolt_project / "zolt.toml").write_text("\n".join(lines) + "\n", encoding="utf-8")


def maven_dependency(coordinate, version, scope=None):
    group, artifact = coordinate.split(":", 1)
    values = [
        "    <dependency>",
        f"      <groupId>{html.escape(group)}</groupId>",
        f"      <artifactId>{html.escape(artifact)}</artifactId>",
    ]
    if version is not None:
        values.append(f"      <version>{html.escape(str(version))}</version>")
    if scope:
        values.append(f"      <scope>{scope}</scope>")
    values.append("    </dependency>")
    return values


def write_maven_config(destination):
    lines = [
        '<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"',
        '         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">',
        "  <modelVersion>4.0.0</modelVersion>",
        f"  <groupId>{html.escape(adapter['group'])}</groupId>",
        f"  <artifactId>{html.escape(adapter['name'])}</artifactId>",
        f"  <version>{html.escape(adapter['version'])}</version>",
        "  <properties>",
        f"    <maven.compiler.release>{int(adapter['compilerRelease'])}</maven.compiler.release>",
        "    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>",
        "  </properties>",
    ]
    platforms = adapter.get("platforms") or {}
    if platforms:
        lines.extend(["  <dependencyManagement>", "  <dependencies>"])
        for coordinate, version in sorted(platforms.items()):
            group, artifact = coordinate.split(":", 1)
            lines.extend([
                "    <dependency>",
                f"      <groupId>{html.escape(group)}</groupId>",
                f"      <artifactId>{html.escape(artifact)}</artifactId>",
                f"      <version>{html.escape(str(version))}</version>",
                "      <type>pom</type>",
                "      <scope>import</scope>",
                "    </dependency>",
            ])
        lines.extend(["  </dependencies>", "  </dependencyManagement>"])
    lines.append("  <dependencies>")
    for coordinate, version in sorted((adapter.get("dependencies") or {}).items()):
        lines.extend(maven_dependency(coordinate, version))
    for coordinate, version in sorted((adapter.get("providedDependencies") or {}).items()):
        lines.extend(maven_dependency(coordinate, version, "provided"))
    lines.extend([
        "  </dependencies>",
        "  <build>",
        "    <plugins>",
        "      <plugin>",
        "        <groupId>org.apache.maven.plugins</groupId>",
        "        <artifactId>maven-compiler-plugin</artifactId>",
        "        <version>3.14.1</version>",
        "      </plugin>",
        "    </plugins>",
        "  </build>",
        "</project>",
    ])
    (destination / "pom.xml").write_text("\n".join(lines) + "\n", encoding="utf-8")


def gradle_quote(value):
    return str(value).replace("\\", "\\\\").replace("'", "\\'")


def write_gradle_config(destination):
    lines = [
        "plugins { id 'java-library' }",
        f"group = '{gradle_quote(adapter['group'])}'",
        f"version = '{gradle_quote(adapter['version'])}'",
        "repositories { mavenCentral() }",
        "java { modularity.inferModulePath = true }",
        "dependencies {",
    ]
    for coordinate, version in sorted((adapter.get("platforms") or {}).items()):
        lines.append(f"    implementation platform('{gradle_quote(coordinate)}:{gradle_quote(version)}')")
    for coordinate, version in sorted((adapter.get("dependencies") or {}).items()):
        notation = coordinate if version is None else f"{coordinate}:{version}"
        lines.append(f"    implementation '{gradle_quote(notation)}'")
    for coordinate, version in sorted((adapter.get("providedDependencies") or {}).items()):
        lines.append(f"    compileOnly '{gradle_quote(coordinate)}:{gradle_quote(version)}'")
    lines.extend([
        "}",
        "tasks.withType(JavaCompile).configureEach {",
        f"    options.release = {int(adapter['compilerRelease'])}",
        "    options.encoding = 'UTF-8'",
        "}",
    ])
    (destination / "build.gradle").write_text("\n".join(lines) + "\n", encoding="utf-8")
    (destination / "settings.gradle").write_text(
        f"rootProject.name = '{gradle_quote(adapter['name'])}'\n", encoding="utf-8"
    )


zolt_cache = cache_dir / "zolt"
maven_cache = cache_dir / "maven"
gradle_no_daemon_cache = cache_dir / "gradle-no-daemon"
gradle_daemon_cache = cache_dir / "gradle-daemon"


def tool_commands():
    zolt = tool_paths["zolt"]
    mvn = tool_paths["maven"]
    gradle = tool_paths["gradle"]
    maven_prefix = [mvn, f"-Dmaven.repo.local={maven_cache}", "-q"]
    gradle_no_daemon_prefix = [
        gradle,
        "--gradle-user-home",
        str(gradle_no_daemon_cache),
        "--no-daemon",
        "--console=plain",
        "--quiet",
    ]
    gradle_daemon_prefix = [
        gradle,
        "--gradle-user-home",
        str(gradle_daemon_cache),
        "--console=plain",
        "--quiet",
    ]
    commands = {
        "zolt": {
            "cwd": zolt_project,
            "resolve": [zolt, "resolve", "--cwd", str(zolt_project), "--cache-root", str(zolt_cache)],
            "build": [zolt, "build", "--cwd", str(zolt_project), "--cache-root", str(zolt_cache)],
            "clean": [zolt, "clean", "--cwd", str(zolt_project)],
        },
        "maven": {
            "cwd": maven_project,
            "resolve": [*maven_prefix, "-DskipTests", "compile"],
            "build": [*maven_prefix, "-DskipTests", "compile"],
            "clean": [*maven_prefix, "clean"],
        },
        "gradle-no-daemon": {
            "cwd": gradle_no_daemon_project,
            "resolve": [*gradle_no_daemon_prefix, "dependencies", "--configuration", "compileClasspath"],
            "build": [*gradle_no_daemon_prefix, "classes"],
            "clean": [*gradle_no_daemon_prefix, "clean"],
        },
        "gradle-daemon": {
            "cwd": gradle_daemon_project,
            "resolve": [*gradle_daemon_prefix, "dependencies", "--configuration", "compileClasspath"],
            "build": [*gradle_daemon_prefix, "classes"],
            "clean": [*gradle_daemon_prefix, "clean"],
        },
    }
    return commands


def median(values):
    return round(statistics.median(values)) if values else None


def metric(command, rows):
    successful = [row for row in rows if row["exitCode"] == 0]
    durations = [row["durationMillis"] for row in successful]
    return {
        "command": command,
        "samples": durations,
        "sampleCount": len(rows),
        "successfulSampleCount": len(successful),
        "timedOutSampleCount": sum(1 for row in rows if row.get("timedOut")),
        "medianMillis": median(durations),
        "minMillis": min(durations) if durations else None,
        "maxMillis": max(durations) if durations else None,
        "logs": [row["log"] for row in rows],
    }


workflow_specs = [
    ("first-clean-build", "Clean compile with warm dependency cache", 1),
    ("warm-no-op-build", "Warm no-op compile", repeat_count),
    ("source-change-build", "Incremental source change compile", repeat_count),
]
commands = tool_commands()
samples = []
workflow_records = []
status = "dry-run" if dry_run else "complete"
failure = None
source_files = None
source_lines = None

environment = {
    "os": platform.platform(),
    "machine": platform.machine(),
    "processor": platform.processor(),
    "python": platform.python_version(),
    "repeatCount": repeat_count,
    "sampleTimeoutSeconds": sample_timeout_seconds,
    "tools": {
        "git": capture_tool(["git", "--version"]),
        "zolt": capture_tool([tool_paths["zolt"], "--version"]),
        "maven": capture_tool([tool_paths["maven"], "--version"]),
        "gradle-no-daemon": capture_tool([tool_paths["gradle"], "--version"]),
        "gradle-daemon": capture_tool([tool_paths["gradle"], "--version"]),
    },
}

if dry_run:
    for workflow_id, label, sample_count in workflow_specs:
        tools = {}
        for tool in tool_ids:
            tools[tool] = {
                "command": commands[tool]["build"],
                "samples": [],
                "sampleCount": sample_count,
                "successfulSampleCount": 0,
                "timedOutSampleCount": 0,
                "medianMillis": None,
                "minMillis": None,
                "maxMillis": None,
                "logs": [],
            }
        workflow_records.append({"id": workflow_id, "label": label, "kind": "comparison", "winner": None, "tools": tools})
else:
    try:
        prepare_checkout()
        source_files, source_lines = prepare_overlays()
        for tool in tool_ids:
            checked(commands[tool]["resolve"], commands[tool]["cwd"], f"setup/{tool}-resolve.log")
            checked(commands[tool]["build"], commands[tool]["cwd"], f"setup/{tool}-build.log")
            checked(commands[tool]["clean"], commands[tool]["cwd"], f"setup/{tool}-clean.log")

        with samples_path.open("w", encoding="utf-8") as sample_stream:
            for workflow_id, label, sample_count in workflow_specs:
                tools = {}
                for tool in tool_ids:
                    rows = []
                    changed_path = commands[tool]["cwd"] / source_change_target
                    baseline = changed_path.read_text(encoding="utf-8")
                    for sample_index in range(1, sample_count + 1):
                        if workflow_id == "first-clean-build":
                            checked(commands[tool]["clean"], commands[tool]["cwd"], f"prepare/{workflow_id}-{tool}-{sample_index:03d}-clean.log")
                        elif workflow_id == "source-change-build":
                            changed_path.write_text(
                                baseline.rstrip() + f"\n// Zolt benchmark source change: {tool} sample {sample_index}\n",
                                encoding="utf-8",
                            )
                        result = run_process(
                            commands[tool]["build"],
                            commands[tool]["cwd"],
                            f"samples/{workflow_id}-{tool}-{sample_index:03d}.log",
                            sample_timeout_seconds,
                        )
                        row = {
                            "project": project_id,
                            "workflow": workflow_id,
                            "workflowLabel": label,
                            "tool": tool,
                            "sample": sample_index,
                            **result,
                        }
                        samples.append(row)
                        rows.append(row)
                        sample_stream.write(json.dumps(row) + "\n")
                        sample_stream.flush()
                        if result["exitCode"] != 0:
                            failure = {
                                "workflow": workflow_id,
                                "tool": tool,
                                "sample": sample_index,
                                "exitCode": result["exitCode"],
                                "log": result["log"],
                            }
                            status = "failed"
                            break
                    if workflow_id == "source-change-build":
                        changed_path.write_text(baseline, encoding="utf-8")
                    tools[tool] = metric(commands[tool]["build"], rows)
                    if failure:
                        break
                successful_medians = {
                    tool: values.get("medianMillis")
                    for tool, values in tools.items()
                    if values.get("medianMillis") is not None
                }
                winner = min(successful_medians, key=successful_medians.get) if len(successful_medians) == len(tool_ids) else None
                workflow_records.append({
                    "id": workflow_id,
                    "label": label,
                    "kind": "comparison",
                    "winner": winner,
                    "tools": tools,
                })
                if failure:
                    break
    except Exception as exc:
        status = "failed"
        failure = {"error": str(exc)}
    finally:
        run_process(
            [tool_paths["gradle"], "--gradle-user-home", str(gradle_daemon_cache), "--stop"],
            work_dir,
            "setup/gradle-daemon-stop.log",
            60,
        )

caveats = [
    "The Zolt, Maven, and Gradle overlays compile the same copied source and resource trees with the same declared release level and dependencies.",
    "Dependency caches are warmed before timed builds; dependency download speed is not measured.",
    "Generated overlay builds do not reproduce every upstream plugin or packaging behavior.",
]
caveats.extend(project.get("coverageNotes") or [])
if dry_run:
    caveats.insert(0, "Dry run only; no repository checkout or timing samples were collected.")
if failure:
    caveats.insert(0, "At least one comparison command failed; inspect the referenced log.")

completed_workflows = sum(
    1
    for row in workflow_records
    if len(row.get("tools") or {}) == len(tool_ids)
    and all((values.get("successfulSampleCount") or 0) == (values.get("sampleCount") or 0) for values in row["tools"].values())
)

project_record = {
    "id": project_id,
    "name": project.get("name"),
    "upstreamUrl": project.get("upstreamUrl"),
    "nativeTool": native_tool,
    "status": project.get("status"),
    "adapterStatus": project.get("adapterStatus"),
    "adapterPath": project.get("adapterPath"),
    "pin": pin,
    "sourceBranch": project.get("sourceBranch"),
}
lane = {
    "id": f"real-{project_id}-comparison",
    "name": f"{project.get('name') or project_id} same-source comparison",
    "kind": "real-project-comparison",
    "status": status,
    "workload": {
        "project": project_record,
        "adapter": {
            "type": adapter.get("type"),
            "sourceFiles": source_files,
            "sourceLines": source_lines,
            "compilerRelease": adapter.get("compilerRelease"),
            "omittedBuildFeatures": adapter.get("omittedBuildFeatures") or [],
        },
    },
    "tools": {
        "zolt": {"label": "Zolt", "version": environment["tools"]["zolt"]},
        "maven": {"label": "Maven", "version": environment["tools"]["maven"]},
        "gradle-no-daemon": {
            "label": "Gradle no-daemon",
            "version": environment["tools"]["gradle-no-daemon"],
        },
        "gradle-daemon": {
            "label": "Gradle daemon",
            "version": environment["tools"]["gradle-daemon"],
        },
    },
    "summary": {
        "classification": "Real-project same-source comparison",
        "completedWorkflowCount": completed_workflows,
        "plannedWorkflowCount": len(workflow_specs),
        "repeatCount": repeat_count,
        "failure": failure,
    },
    "environment": environment,
    "workflows": workflow_records,
    "caveats": caveats,
    "artifacts": {
        "summary": rel(summary_path),
        "suiteSummary": rel(suite_path),
        "samples": rel(samples_path),
        "report": rel(report_path),
        "logs": rel(logs_dir),
        "adapter": rel(adapter_path),
        "checkout": rel(checkout_dir) if checkout_dir.exists() else None,
    },
}

run_url = None
if os.environ.get("GITHUB_SERVER_URL") and os.environ.get("GITHUB_REPOSITORY") and os.environ.get("GITHUB_RUN_ID"):
    run_url = f"{os.environ['GITHUB_SERVER_URL']}/{os.environ['GITHUB_REPOSITORY']}/actions/runs/{os.environ['GITHUB_RUN_ID']}"
repository = {
    "name": os.environ.get("GITHUB_REPOSITORY"),
    "ref": os.environ.get("GITHUB_REF_NAME"),
    "commit": os.environ.get("GITHUB_SHA"),
    "runId": os.environ.get("GITHUB_RUN_ID"),
    "runUrl": run_url,
}

summary = {
    "schemaVersion": 2,
    "createdAt": now_iso(),
    "project": project_record,
    "status": status,
    "coverage": coverage,
    "environment": environment,
    "workflows": workflow_records,
    "samples": samples,
    "caveats": caveats,
    "failure": failure,
}
suite = {
    "schemaVersion": 2,
    "createdAt": now_iso(),
    "suite": {"name": "zolt-real-project-benchmark", "mode": "four-way-comparison"},
    "repository": repository,
    "run": {
        "classification": lane["summary"]["classification"],
        "laneCount": 1,
        "completedLaneCount": 1 if status == "complete" else 0,
    },
    "lanes": [lane],
}

summary_path.write_text(json.dumps(summary, indent=2) + "\n", encoding="utf-8")
suite_path.write_text(json.dumps(suite, indent=2) + "\n", encoding="utf-8")

lines = [
    f"# {project.get('name') or project_id} Same-Source Comparison",
    "",
    f"- Project: `{project_id}`",
    f"- Pin: `{pin_value}`",
    f"- Adapter: `{project.get('adapterPath')}`",
    f"- Status: `{status}`",
    "",
    "| Workflow | Winner | Zolt | Maven | Gradle no-daemon | Gradle daemon |",
    "| --- | --- | ---: | ---: | ---: | ---: |",
]
for workflow in workflow_records:
    tools = workflow.get("tools") or {}
    zolt_ms = (tools.get("zolt") or {}).get("medianMillis")
    maven_ms = (tools.get("maven") or {}).get("medianMillis")
    gradle_no_daemon_ms = (tools.get("gradle-no-daemon") or {}).get("medianMillis")
    gradle_daemon_ms = (tools.get("gradle-daemon") or {}).get("medianMillis")
    fmt = lambda value: f"{value:,} ms" if isinstance(value, (int, float)) else "n/a"
    lines.append(
        f"| {workflow.get('label')} | {workflow.get('winner') or 'n/a'} | {fmt(zolt_ms)} | {fmt(maven_ms)} | {fmt(gradle_no_daemon_ms)} | {fmt(gradle_daemon_ms)} |"
    )
if failure:
    lines.extend(["", f"Failure: `{json.dumps(failure, sort_keys=True)}`"])
lines.extend(["", "## Caveats", ""])
lines.extend(f"- {item}" for item in caveats)
lines.append("")
report_path.write_text("\n".join(lines), encoding="utf-8")

print(f"wrote real-project comparison summary: {summary_path}")
print(f"wrote real-project suite lane: {suite_path}")
print(f"wrote real-project report: {report_path}")

if failure:
    raise SystemExit(1)
PY
