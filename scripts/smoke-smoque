#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
NPM_CONFIG_CACHE="${NPM_CONFIG_CACHE:-/tmp/zolt-smoque-npm-cache}"
SMOQUE_PACKAGE="${SMOQUE_PACKAGE:-smoque@alpha}"
export NPM_CONFIG_CACHE

cd "$ROOT"
case "${1:-}" in
  *.smoke.mts | */*.smoke.mts)
    exec npx --yes "$SMOQUE_PACKAGE" run "$@"
    ;;
  container)
    shift
    exec npx --yes "$SMOQUE_PACKAGE" run ci/smoke/container/ "$@"
    ;;
  native)
    shift
    exec npx --yes "$SMOQUE_PACKAGE" run ci/smoke/native/ "$@"
    ;;
  native-container)
    shift
    exec npx --yes "$SMOQUE_PACKAGE" run ci/smoke/native-container/ "$@"
    ;;
  agents | doctor | init | list | run | snippets | --help | -h | --version)
    exec npx --yes "$SMOQUE_PACKAGE" "$@"
    ;;
  *)
    exec npx --yes "$SMOQUE_PACKAGE" run smoke/ "$@"
    ;;
esac
