#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

WORK_DIR="target/benchmarks/competitors"
OUTPUT_FILE=""
SUMMARY_BRIEF=""
PROJECT_MANIFEST="docs/benchmarks/projects.json"
MODULE_COUNT=40
REPEAT_COUNT=5
LAYER_WIDTH=8
CLASSES_PER_MODULE=1
METHODS_PER_CLASS=1
ZOLT_BIN="${ZOLT_BENCH_ZOLT:-}"
MAVEN_BIN="${ZOLT_BENCH_MAVEN:-}"
GRADLE_BIN="${ZOLT_BENCH_GRADLE:-}"
INCLUDE_GRADLE_DAEMON=false
GENERATED_SUMMARY=""
GENERATED_TOPOLOGIES=()
SKIP_GENERATED=false
REAL_PROJECTS=()
REAL_PROJECT_DRY_RUN=false
REAL_PROJECT_SAMPLE_TIMEOUT_SECONDS=1800
ARTIFACT_NAME=""
SUITE_FAILED=false

usage() {
  cat <<'USAGE'
Usage: scripts/benchmark-suite [options]

Runs selected benchmark lanes and writes a suite-level summary.

Options:
  --work-dir DIR              Suite output directory. Default: target/benchmarks/competitors.
  --output FILE               Suite summary JSON. Default: WORK_DIR/suite-summary.json.
  --summary-brief FILE        Deterministic Markdown summary. Default: WORK_DIR/summary-brief.md.
  --project-manifest FILE     Real-project manifest. Default: docs/benchmarks/projects.json.
  --modules COUNT             Generated workspace module count. Default: 40.
  --repeat COUNT              Generated workspace repeated samples. Default: 5.
  --topology SHAPE            Generated graph: chain, wide, or layered. Repeatable.
  --topologies SHAPES         Comma-separated generated graph shapes. Default: wide.
  --layer-width COUNT         Parallel members per layered wave. Default: 8.
  --classes-per-module N      Generated Java classes per library module. Default: 1.
  --methods-per-class N       Methods per generated payload class. Default: 1.
  --zolt PATH                 Zolt executable passed to generated lane.
  --maven PATH                Maven executable passed to generated lane.
  --gradle PATH               Gradle executable passed to generated lane.
  --include-gradle-daemon     Include Gradle daemon in generated lane.
  --generated-summary FILE    Use an existing generated-lane summary instead of running it.
  --skip-generated            Do not run or summarize the generated lane.
  --real-project ID           Run a pinned real-project same-source comparison. Repeatable.
  --real-projects IDS         Comma-separated real-project ids.
  --real-project-dry-run      Validate real-project lanes without cloning or timing.
  --real-project-sample-timeout SECONDS
                             Per-command timeout for real-project lanes. Default: 1800.
  --artifact-name NAME        Uploaded artifact name recorded in the suite summary.
  -h, --help                  Show this help.
USAGE
}

fail() {
  printf 'error: %s\n' "$1" >&2
  exit 1
}

positive_int() {
  [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

abs_path() {
  case "$1" in
    "") printf '\n' ;;
    /*) printf '%s\n' "$1" ;;
    *) printf '%s\n' "$ROOT/$1" ;;
  esac
}

add_real_projects() {
  local value="$1"
  local part
  local -a parts
  IFS=',' read -r -a parts <<<"$value"
  for part in "${parts[@]}"; do
    part="${part#"${part%%[![:space:]]*}"}"
    part="${part%"${part##*[![:space:]]}"}"
    if [[ -n "$part" ]]; then
      REAL_PROJECTS+=("$part")
    fi
  done
}

add_topologies() {
  local value="$1"
  local part
  local -a parts
  IFS=',' read -r -a parts <<<"$value"
  for part in "${parts[@]}"; do
    part="${part#"${part%%[![:space:]]*}"}"
    part="${part%"${part##*[![:space:]]}"}"
    case "$part" in
      chain | wide | layered) GENERATED_TOPOLOGIES+=("$part") ;;
      "") ;;
      *) fail "generated topology must be chain, wide, or layered: $part" ;;
    esac
  done
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --work-dir)
      [[ "$#" -ge 2 ]] || fail "--work-dir requires a value"
      WORK_DIR="$2"
      shift 2
      ;;
    --output)
      [[ "$#" -ge 2 ]] || fail "--output requires a value"
      OUTPUT_FILE="$2"
      shift 2
      ;;
    --summary-brief)
      [[ "$#" -ge 2 ]] || fail "--summary-brief requires a value"
      SUMMARY_BRIEF="$2"
      shift 2
      ;;
    --project-manifest)
      [[ "$#" -ge 2 ]] || fail "--project-manifest requires a value"
      PROJECT_MANIFEST="$2"
      shift 2
      ;;
    --modules)
      [[ "$#" -ge 2 ]] || fail "--modules requires a value"
      positive_int "$2" || fail "--modules requires a positive integer"
      MODULE_COUNT="$2"
      shift 2
      ;;
    --repeat)
      [[ "$#" -ge 2 ]] || fail "--repeat requires a value"
      positive_int "$2" || fail "--repeat requires a positive integer"
      REPEAT_COUNT="$2"
      shift 2
      ;;
    --topology)
      [[ "$#" -ge 2 ]] || fail "--topology requires a value"
      add_topologies "$2"
      shift 2
      ;;
    --topologies)
      [[ "$#" -ge 2 ]] || fail "--topologies requires a value"
      add_topologies "$2"
      shift 2
      ;;
    --layer-width)
      [[ "$#" -ge 2 ]] || fail "--layer-width requires a value"
      positive_int "$2" || fail "--layer-width requires a positive integer"
      LAYER_WIDTH="$2"
      shift 2
      ;;
    --classes-per-module)
      [[ "$#" -ge 2 ]] || fail "--classes-per-module requires a value"
      positive_int "$2" || fail "--classes-per-module requires a positive integer"
      CLASSES_PER_MODULE="$2"
      shift 2
      ;;
    --methods-per-class)
      [[ "$#" -ge 2 ]] || fail "--methods-per-class requires a value"
      positive_int "$2" || fail "--methods-per-class requires a positive integer"
      METHODS_PER_CLASS="$2"
      shift 2
      ;;
    --zolt)
      [[ "$#" -ge 2 ]] || fail "--zolt requires a value"
      ZOLT_BIN="$2"
      shift 2
      ;;
    --maven)
      [[ "$#" -ge 2 ]] || fail "--maven requires a value"
      MAVEN_BIN="$2"
      shift 2
      ;;
    --gradle)
      [[ "$#" -ge 2 ]] || fail "--gradle requires a value"
      GRADLE_BIN="$2"
      shift 2
      ;;
    --include-gradle-daemon)
      INCLUDE_GRADLE_DAEMON=true
      shift
      ;;
    --generated-summary)
      [[ "$#" -ge 2 ]] || fail "--generated-summary requires a value"
      GENERATED_SUMMARY="$2"
      shift 2
      ;;
    --skip-generated)
      SKIP_GENERATED=true
      shift
      ;;
    --real-project)
      [[ "$#" -ge 2 ]] || fail "--real-project requires a value"
      add_real_projects "$2"
      shift 2
      ;;
    --real-projects)
      [[ "$#" -ge 2 ]] || fail "--real-projects requires a value"
      add_real_projects "$2"
      shift 2
      ;;
    --real-project-dry-run)
      REAL_PROJECT_DRY_RUN=true
      shift
      ;;
    --real-project-sample-timeout)
      [[ "$#" -ge 2 ]] || fail "--real-project-sample-timeout requires a value"
      positive_int "$2" || fail "--real-project-sample-timeout requires a positive integer"
      REAL_PROJECT_SAMPLE_TIMEOUT_SECONDS="$2"
      shift 2
      ;;
    --artifact-name)
      [[ "$#" -ge 2 ]] || fail "--artifact-name requires a value"
      ARTIFACT_NAME="$2"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option '$1'"
      ;;
  esac
done

case "$WORK_DIR" in
  "" | "." | "/" | "$ROOT")
    fail "refusing unsafe benchmark work directory: $WORK_DIR"
    ;;
esac

WORK_DIR="$(abs_path "$WORK_DIR")"
PROJECT_MANIFEST="$(abs_path "$PROJECT_MANIFEST")"
if [[ -z "$OUTPUT_FILE" ]]; then
  OUTPUT_FILE="$WORK_DIR/suite-summary.json"
else
  OUTPUT_FILE="$(abs_path "$OUTPUT_FILE")"
fi
if [[ -z "$SUMMARY_BRIEF" ]]; then
  SUMMARY_BRIEF="$WORK_DIR/summary-brief.md"
else
  SUMMARY_BRIEF="$(abs_path "$SUMMARY_BRIEF")"
fi
if [[ -n "$GENERATED_SUMMARY" ]]; then
  GENERATED_SUMMARY="$(abs_path "$GENERATED_SUMMARY")"
fi
if [[ "${#GENERATED_TOPOLOGIES[@]}" -eq 0 ]]; then
  GENERATED_TOPOLOGIES=(wide)
fi
if [[ -n "$GENERATED_SUMMARY" && "${#GENERATED_TOPOLOGIES[@]}" -ne 1 ]]; then
  fail "--generated-summary can only be used with one generated topology"
fi

mkdir -p "$WORK_DIR" "$(dirname "$OUTPUT_FILE")" "$(dirname "$SUMMARY_BRIEF")"

lane_summaries=()
if [[ "$SKIP_GENERATED" == false ]]; then
  for topology in "${GENERATED_TOPOLOGIES[@]}"; do
    generated_dir="$WORK_DIR/generated-java-workspace-$topology"
    generated_summary="$GENERATED_SUMMARY"
    mkdir -p "$generated_dir"

    if [[ -z "$generated_summary" ]]; then
      generated_args=(
        --modules "$MODULE_COUNT"
        --repeat "$REPEAT_COUNT"
        --topology "$topology"
        --layer-width "$LAYER_WIDTH"
        --classes-per-module "$CLASSES_PER_MODULE"
        --methods-per-class "$METHODS_PER_CLASS"
        --work-dir "$generated_dir"
      )
      if [[ -n "$ZOLT_BIN" ]]; then
        generated_args+=(--zolt "$ZOLT_BIN")
      fi
      if [[ -n "$MAVEN_BIN" ]]; then
        generated_args+=(--maven "$MAVEN_BIN")
      fi
      if [[ -n "$GRADLE_BIN" ]]; then
        generated_args+=(--gradle "$GRADLE_BIN")
      fi
      if [[ "$INCLUDE_GRADLE_DAEMON" == true ]]; then
        generated_args+=(--include-gradle-daemon)
      fi
      scripts/benchmark-competitors "${generated_args[@]}"
      generated_summary="$generated_dir/summary.json"
    fi

    scripts/benchmark-llm-summary \
      --summary "$generated_summary" \
      --output-dir "$generated_dir"

    generated_artifact_name="$ARTIFACT_NAME"
    if [[ -z "$generated_artifact_name" ]]; then
      generated_artifact_name="zolt-benchmark-generated-${topology}-${MODULE_COUNT}-modules-${REPEAT_COUNT}-repeats"
    fi
    case "$topology" in
      chain) topology_name="Serial chain" ;;
      wide) topology_name="Wide fan-out" ;;
      layered) topology_name="Layered DAG" ;;
    esac

    scripts/benchmark-suite-summary \
      --summary "$generated_summary" \
      --output "$generated_dir/suite-summary.json" \
      --lane-id "generated-java-workspace-$topology" \
      --lane-name "Generated Java workspace: $topology_name" \
      --lane-kind generated \
      --artifact-name "$generated_artifact_name"

    lane_summaries+=("$generated_dir/suite-summary.json")
  done
fi

if [[ "${#REAL_PROJECTS[@]}" -gt 0 ]]; then
  for project_id in "${REAL_PROJECTS[@]}"; do
    project_dir="$WORK_DIR/real-projects/$project_id"
    mkdir -p "$project_dir"

    real_project_args=(
      --project "$project_id"
      --project-manifest "$PROJECT_MANIFEST"
      --work-dir "$project_dir"
      --cache-dir "$WORK_DIR/real-project-cache"
      --repeat "$REPEAT_COUNT"
      --sample-timeout "$REAL_PROJECT_SAMPLE_TIMEOUT_SECONDS"
    )
    if [[ -n "$ZOLT_BIN" ]]; then
      real_project_args+=(--zolt "$ZOLT_BIN")
    fi
    if [[ -n "$MAVEN_BIN" ]]; then
      real_project_args+=(--maven "$MAVEN_BIN")
    fi
    if [[ -n "$GRADLE_BIN" ]]; then
      real_project_args+=(--gradle "$GRADLE_BIN")
    fi
    if [[ "$REAL_PROJECT_DRY_RUN" == true ]]; then
      real_project_args+=(--dry-run)
    fi

    if ! scripts/benchmark-real-project "${real_project_args[@]}"; then
      SUITE_FAILED=true
    fi
    if [[ -f "$project_dir/suite-summary.json" ]]; then
      lane_summaries+=("$project_dir/suite-summary.json")
    else
      fail "real-project lane did not write suite summary: $project_id"
    fi
  done
fi

python3 - "$OUTPUT_FILE" "$SUMMARY_BRIEF" "$PROJECT_MANIFEST" "$ARTIFACT_NAME" "${lane_summaries[@]}" <<'PY'
import json
import os
import pathlib
import sys
from datetime import datetime, timezone

output_path = pathlib.Path(sys.argv[1])
summary_brief_path = pathlib.Path(sys.argv[2])
manifest_path = pathlib.Path(sys.argv[3])
artifact_name = sys.argv[4] or None
lane_summary_paths = [pathlib.Path(path) for path in sys.argv[5:]]

workflow_order = [
    "setup-warm-build",
    "first-clean-build",
    "dependency-setup",
    "no-op-build",
    "warm-no-op-build",
    "leaf-change-build",
    "source-change-build",
    "root-change-build",
    "sequential-clean-compile-all",
    "parallel-clean-compile-all",
    "clean-compile-single-module",
    "warm-no-op-single-module",
    "implementation-change-common",
    "public-api-change-common",
    "package-or-install",
    "test",
]
workflow_labels = {
    "setup-warm-build": "First clean build",
    "no-op-build": "Warm no-op",
    "leaf-change-build": "Leaf source change",
    "root-change-build": "Root library change",
    "first-clean-build": "First clean build",
    "warm-no-op-build": "Warm no-op",
    "source-change-build": "Source change",
    "test": "Test",
    "dependency-setup": "Dependency setup",
    "sequential-clean-compile-all": "Sequential clean compile all",
    "parallel-clean-compile-all": "Parallel clean compile all",
    "clean-compile-single-module": "Clean compile single module",
    "warm-no-op-single-module": "Warm no-op single module",
    "implementation-change-common": "Implementation change in common",
    "public-api-change-common": "Public API change in common",
    "package-or-install": "Package or install",
}
tool_order = ["zolt", "maven", "gradle", "gradle-no-daemon", "gradle-daemon"]
tool_labels = {
    "zolt": "Zolt",
    "maven": "Maven",
    "gradle": "Gradle",
    "gradle-no-daemon": "Gradle no-daemon",
    "gradle-daemon": "Gradle daemon",
}


def load_json(path):
    return json.loads(path.read_text(encoding="utf-8"))


def first_present(*values):
    for value in values:
        if value not in (None, "", [], {}):
            return value
    return None


def fmt_ms(value):
    if not isinstance(value, (int, float)):
        return "n/a"
    return f"{int(value):,} ms"


def fmt_command(command):
    if not command:
        return "n/a"
    return "`" + " ".join(str(part) for part in command).replace("|", "\\|") + "`"


def metric_status(metrics, lane):
    lane_status = lane.get("status")
    if lane_status == "dry-run":
        return "dry run"
    if (metrics.get("timedOutSampleCount") or 0) > 0:
        return "timed out"
    sample_count = metrics.get("sampleCount") or 0
    successful_count = metrics.get("successfulSampleCount") or 0
    if sample_count and successful_count == sample_count:
        return "complete"
    if sample_count:
        return "failed"
    return lane_status or "planned"


def workflow_sort_key(workflow):
    workflow_id = workflow.get("id")
    if workflow_id in workflow_order:
        return (workflow_order.index(workflow_id), workflow_id)
    return (len(workflow_order), workflow_id or "")


def planned_projects(path):
    if not path.is_file():
        return []
    manifest = load_json(path)
    return sorted(
        [
            {
                "id": project.get("id"),
                "name": project.get("name"),
                "upstreamUrl": project.get("upstreamUrl"),
                "nativeTool": project.get("nativeTool"),
                "status": project.get("status"),
                "adapterStatus": project.get("adapterStatus"),
                "adapterPath": project.get("adapterPath"),
                "priority": project.get("priority"),
                "pin": project.get("pin"),
                "workflows": project.get("workflows") or [],
                "coverageNotes": project.get("coverageNotes") or [],
            }
            for project in manifest.get("projects", [])
        ],
        key=lambda project: (project.get("priority") or 999, project.get("id") or ""),
    )


lane_summaries = [load_json(path) for path in lane_summary_paths if path.is_file()]
lanes = []
for lane_summary in lane_summaries:
    lanes.extend(lane_summary.get("lanes", []))

repository = {}
for lane_summary in lane_summaries:
    repository = first_present(lane_summary.get("repository")) or {}
    if repository:
        break
if not repository:
    run_url = None
    if os.environ.get("GITHUB_SERVER_URL") and os.environ.get("GITHUB_REPOSITORY") and os.environ.get("GITHUB_RUN_ID"):
        run_url = (
            f"{os.environ['GITHUB_SERVER_URL']}/"
            f"{os.environ['GITHUB_REPOSITORY']}/actions/runs/"
            f"{os.environ['GITHUB_RUN_ID']}"
        )
    repository = {
        "name": os.environ.get("GITHUB_REPOSITORY"),
        "ref": os.environ.get("GITHUB_REF_NAME"),
        "commit": os.environ.get("GITHUB_SHA"),
        "runId": os.environ.get("GITHUB_RUN_ID"),
        "runUrl": run_url,
    }

projects = planned_projects(manifest_path)
classifications = [
    ((lane.get("summary") or {}).get("classification"))
    for lane in lanes
    if ((lane.get("summary") or {}).get("classification"))
]
has_generated_lane = any(lane.get("kind") == "generated" for lane in lanes)
has_real_project_lane = any(lane.get("kind") == "real-project-comparison" for lane in lanes)
classification = "Planned benchmark suite"
if classifications:
    if has_generated_lane and has_real_project_lane:
        classification = "Generated and real-project comparisons"
    elif any(value == "Production-grade generated evidence" for value in classifications):
        classification = "Production-grade generated evidence"
    elif any(value == "Exploratory benchmark" for value in classifications):
        classification = "Exploratory benchmark"
    else:
        classification = classifications[0]

suite = {
    "schemaVersion": 1,
    "createdAt": datetime.now(timezone.utc).isoformat(),
    "suite": {
        "name": "zolt-benchmark-suite",
        "mode": "multi-lane",
    },
    "repository": repository,
    "run": {
        "classification": classification,
        "laneCount": len(lanes),
        "completedLaneCount": sum(1 for lane in lanes if lane.get("status") == "complete"),
        "configuredProjectCount": len(projects),
        "artifactName": artifact_name,
    },
    "lanes": lanes,
    "configuredProjects": projects,
    "artifacts": {
        "suiteSummary": str(output_path),
        "summaryBrief": str(summary_brief_path),
        "projectManifest": str(manifest_path) if manifest_path.is_file() else None,
    },
}

output_path.write_text(json.dumps(suite, indent=2) + "\n", encoding="utf-8")

lines = ["# Benchmark Suite Summary", ""]
if lanes:
    lane_count = len(lanes)
    completed = suite["run"]["completedLaneCount"]
    generated_count = sum(1 for lane in lanes if lane.get("kind") == "generated")
    real_project_count = sum(1 for lane in lanes if lane.get("kind") == "real-project-comparison")
    lane_parts = []
    if generated_count:
        lane_parts.append(f"{generated_count} generated comparison{'s' if generated_count != 1 else ''}")
    if real_project_count:
        lane_parts.append(f"{real_project_count} real-project comparison{'s' if real_project_count != 1 else ''}")
    if lane_parts:
        lines.append(
            f"This suite contains {lane_count} benchmark lane{'s' if lane_count != 1 else ''}: "
            + " and ".join(lane_parts)
            + "."
        )
    else:
        lines.append(f"This suite contains {lane_count} benchmark lane{'s' if lane_count != 1 else ''}.")
    lines.append(f"Completed lanes: {completed}.")
    if projects:
        lines.append(f"{len(projects)} real-project lanes are configured in the manifest.")
    lines.append("")

    comparison_rows = []
    native_rows = []
    failed_rows = []
    for lane in lanes:
        lane_name = lane.get("name") or lane.get("id") or "Benchmark lane"
        workflows = lane.get("workflows", [])
        if lane.get("status") == "failed" and not workflows:
            failure = (lane.get("summary") or {}).get("failure") or {}
            failed_rows.append([
                lane_name,
                failure.get("error") or json.dumps(failure, sort_keys=True),
            ])
        for workflow in sorted(workflows, key=workflow_sort_key):
            workflow_id = workflow.get("id")
            tools = workflow.get("tools") or {}
            if len(tools) <= 1:
                if tools and lane.get("kind") == "real-project-comparison":
                    tool = next(iter(tools))
                    metrics = tools[tool] or {}
                    native_rows.append([
                        lane_name,
                        workflow_labels.get(workflow_id, workflow.get("label") or workflow_id or "unknown"),
                        tool_labels.get(tool, tool),
                        metric_status(metrics, lane),
                        fmt_ms(metrics.get("medianMillis")),
                        str(metrics.get("successfulSampleCount") or 0),
                        fmt_command(metrics.get("command")),
                    ])
                continue
            row = [
                lane_name,
                workflow_labels.get(workflow_id, workflow.get("label") or workflow_id or "unknown"),
                tool_labels.get(workflow.get("winner"), workflow.get("winner") or "n/a"),
            ]
            row.extend(fmt_ms((tools.get(tool) or {}).get("medianMillis")) for tool in ["zolt", "maven", "gradle", "gradle-no-daemon", "gradle-daemon"])
            comparison_rows.append(row)

    if comparison_rows:
        lines.extend([
            "## Comparison Results",
            "",
            "| Workload | Workflow | Winner | Zolt | Maven | Gradle | Gradle no-daemon | Gradle daemon |",
            "| --- | --- | --- | ---: | ---: | ---: | ---: | ---: |",
        ])
        for row in comparison_rows:
            lines.append("| " + " | ".join(row) + " |")
        lines.append("")

    if native_rows:
        lines.extend([
            "## Upstream Tool Baselines",
            "",
            "| Project | Workflow | Tool | Status | Median | Samples | Command |",
            "| --- | --- | --- | --- | ---: | ---: | --- |",
        ])
        for row in native_rows:
            lines.append("| " + " | ".join(row) + " |")
        lines.append("")

    if failed_rows:
        lines.extend([
            "## Failed Lanes",
            "",
            "| Lane | Failure |",
            "| --- | --- |",
        ])
        for row in failed_rows:
            lines.append("| " + " | ".join(value.replace("|", "\\|") for value in row) + " |")
        lines.append("")
else:
    lines.append("No benchmark lanes completed in this run.")
    lines.append("")

if projects:
    project_run_status = {}
    for lane in lanes:
        if lane.get("kind") != "real-project-comparison":
            continue
        project = ((lane.get("workload") or {}).get("project") or {})
        project_id = project.get("id")
        if project_id:
            project_run_status[project_id] = lane.get("status") or "unknown"
    lines.extend([
        "## Configured Real-Project Lanes",
        "",
        "| Project | Upstream tool | Manifest status | Adapter | Run status | Pin |",
        "| --- | --- | --- | --- | --- | --- |",
    ])
    for project in projects:
        pin = project.get("pin") or {}
        pin_value = pin.get("value") or "needs pin"
        adapter_status = project.get("adapterStatus") or "unknown"
        adapter_path = project.get("adapterPath")
        adapter_text = adapter_status
        if adapter_path:
            adapter_text = f"{adapter_status} ({adapter_path})"
        lines.append(
            "| "
            + " | ".join([
                project.get("name") or project.get("id") or "unknown",
                project.get("nativeTool") or "unknown",
                project.get("status") or "unknown",
                adapter_text,
                project_run_status.get(project.get("id"), "not run"),
                pin_value,
            ])
            + " |"
        )
    lines.append("")

summary_brief_path.write_text("\n".join(lines), encoding="utf-8")
PY

cp "$SUMMARY_BRIEF" "$WORK_DIR/llm-summary.md"

printf 'wrote benchmark suite summary: %s\n' "$OUTPUT_FILE"
printf 'wrote benchmark suite brief: %s\n' "$SUMMARY_BRIEF"

if [[ "$SUITE_FAILED" == true ]]; then
  printf 'one or more benchmark lanes failed; see suite summary and lane logs\n' >&2
  exit 1
fi
