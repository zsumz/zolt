#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

JAR_PATH="${ZOLT_JAR:-}"
RUNTIME_CLASSPATH_FILE="${ZOLT_RUNTIME_CLASSPATH_FILE:-}"
WORKER_JAR_PATH="${ZOLT_JUNIT_WORKER_JAR:-}"
JAVAC_WORKER_JAR_PATH="${ZOLT_JAVAC_WORKER_JAR:-}"
java_opts=()
if [[ -n "${ZOLT_JAVA_OPTS:-}" ]]; then
  read -r -a java_opts <<< "$ZOLT_JAVA_OPTS"
fi

if [[ -z "$JAR_PATH" ]]; then
  shopt -s nullglob
  jars=(apps/zolt/target/*.jar)
  shopt -u nullglob
  if [[ "${#jars[@]}" -ne 1 ]]; then
    printf 'error: expected exactly one Zolt-built jar under apps/zolt/target/, found %s\n' "${#jars[@]}" >&2
    printf 'hint: run zolt self-check or zolt package before scripts/run-zolt-built\n' >&2
    exit 1
  fi
  JAR_PATH="${jars[0]}"
fi

if [[ ! -f "$JAR_PATH" ]]; then
  printf 'error: Zolt-built jar does not exist at %s\n' "$JAR_PATH" >&2
  printf 'hint: run zolt self-check or zolt package before scripts/run-zolt-built\n' >&2
  exit 1
fi

if [[ -z "$RUNTIME_CLASSPATH_FILE" ]]; then
  RUNTIME_CLASSPATH_FILE="${JAR_PATH%.jar}.runtime-classpath"
fi

runtime_cp=""
if [[ ! -f "$RUNTIME_CLASSPATH_FILE" ]]; then
  printf 'error: runtime classpath sidecar does not exist at %s\n' "$RUNTIME_CLASSPATH_FILE" >&2
  printf 'hint: run zolt package or zolt self-check before scripts/run-zolt-built\n' >&2
  exit 1
fi

while IFS= read -r entry || [[ -n "$entry" ]]; do
  if [[ -z "$entry" ]]; then
    continue
  fi
  if [[ -z "$runtime_cp" ]]; then
    runtime_cp="$entry"
  else
    runtime_cp="${runtime_cp}:${entry}"
  fi
done < "$RUNTIME_CLASSPATH_FILE"

RUN_JAR_PATH="$JAR_PATH"
TEMP_RUN_DIR=""
cleanup() {
  if [[ -n "$TEMP_RUN_DIR" ]]; then
    rm -rf "$TEMP_RUN_DIR"
  fi
}
trap cleanup EXIT

if [[ "${ZOLT_RUN_BUILT_IN_PLACE:-}" != "1" ]]; then
  TEMP_RUN_DIR="$(mktemp -d "${TMPDIR:-/tmp}/zolt-run-built.XXXXXX")"
  RUN_JAR_PATH="$TEMP_RUN_DIR/$(basename "$JAR_PATH")"
  cp "$JAR_PATH" "$RUN_JAR_PATH"
fi

if [[ -n "$runtime_cp" ]]; then
  classpath="${RUN_JAR_PATH}:${runtime_cp}"
else
  classpath="$RUN_JAR_PATH"
fi

if [[ -z "$WORKER_JAR_PATH" ]]; then
  shopt -s nullglob
  worker_jars=(apps/zolt-junit-worker/target/*.jar)
  shopt -u nullglob
  if [[ "${#worker_jars[@]}" -eq 1 ]]; then
    WORKER_JAR_PATH="${worker_jars[0]}"
  fi
fi

if [[ -n "$WORKER_JAR_PATH" ]]; then
  if [[ ! -f "$WORKER_JAR_PATH" ]]; then
    printf 'error: Zolt JUnit worker jar does not exist at %s\n' "$WORKER_JAR_PATH" >&2
    printf 'hint: run zolt package --workspace --member apps/zolt-junit-worker before scripts/run-zolt-built\n' >&2
    exit 1
  fi
  if [[ "${#java_opts[@]}" -gt 0 ]]; then
    java_opts=("-Dzolt.junit.worker.classpath=${WORKER_JAR_PATH}" "${java_opts[@]}")
  else
    java_opts=("-Dzolt.junit.worker.classpath=${WORKER_JAR_PATH}")
  fi
fi

if [[ -z "$JAVAC_WORKER_JAR_PATH" ]]; then
  shopt -s nullglob
  javac_worker_jars=(apps/zolt-javac-worker/target/*.jar)
  shopt -u nullglob
  if [[ "${#javac_worker_jars[@]}" -eq 1 ]]; then
    JAVAC_WORKER_JAR_PATH="${javac_worker_jars[0]}"
  fi
fi

if [[ -n "$JAVAC_WORKER_JAR_PATH" ]]; then
  if [[ ! -f "$JAVAC_WORKER_JAR_PATH" ]]; then
    printf 'error: Zolt javac worker jar does not exist at %s\n' "$JAVAC_WORKER_JAR_PATH" >&2
    printf 'hint: run zolt package --workspace --member apps/zolt-javac-worker before scripts/run-zolt-built\n' >&2
    exit 1
  fi
  java_opts=("-Dzolt.javac.worker.classpath=${JAVAC_WORKER_JAR_PATH}" "${java_opts[@]}")
fi

if [[ "${#java_opts[@]}" -gt 0 ]]; then
  java "${java_opts[@]}" -cp "$classpath" sh.zolt.cli.ZoltCli "$@"
else
  java -cp "$classpath" sh.zolt.cli.ZoltCli "$@"
fi
