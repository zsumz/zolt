#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

CACHE_ROOT="${ZOLT_CACHE_ROOT:-.zolt/cache}"
JAR_PATH="${ZOLT_JAR:-}"
RUNTIME_CLASSPATH_FILE="${ZOLT_RUNTIME_CLASSPATH_FILE:-}"

if [[ -z "$JAR_PATH" ]]; then
  shopt -s nullglob
  jars=(target/*.jar)
  shopt -u nullglob
  if [[ "${#jars[@]}" -ne 1 ]]; then
    printf 'error: expected exactly one Zolt-built jar under target/, found %s\n' "${#jars[@]}" >&2
    printf 'hint: run zolt self-check or zolt package before scripts/run-zolt-built\n' >&2
    exit 1
  fi
  JAR_PATH="${jars[0]}"
fi

if [[ ! -f "$JAR_PATH" ]]; then
  printf 'error: Zolt-built jar does not exist at %s\n' "$JAR_PATH" >&2
  printf 'hint: run zolt self-check or zolt package before scripts/run-zolt-built\n' >&2
  exit 1
fi

if [[ -z "$RUNTIME_CLASSPATH_FILE" ]]; then
  RUNTIME_CLASSPATH_FILE="${JAR_PATH%.jar}.runtime-classpath"
fi

runtime_cp=""
if [[ -f "$RUNTIME_CLASSPATH_FILE" ]]; then
  while IFS= read -r entry || [[ -n "$entry" ]]; do
    if [[ -z "$entry" ]]; then
      continue
    fi
    if [[ -z "$runtime_cp" ]]; then
      runtime_cp="$entry"
    else
      runtime_cp="${runtime_cp}:${entry}"
    fi
  done < "$RUNTIME_CLASSPATH_FILE"
else
  printf 'warning: runtime classpath sidecar not found at %s; falling back to Gradle bootstrap\n' "$RUNTIME_CLASSPATH_FILE" >&2
  runtime_cp="$(./gradlew -q run --args="classpath runtime --cache-root ${CACHE_ROOT}" --warning-mode all)"
fi

if [[ -n "$runtime_cp" ]]; then
  classpath="${JAR_PATH}:${runtime_cp}"
else
  classpath="$JAR_PATH"
fi

exec java -cp "$classpath" com.zolt.cli.ZoltCli "$@"
