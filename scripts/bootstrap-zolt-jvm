#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

CACHE_ROOT="${ZOLT_CACHE_ROOT:-.zolt/cache}"
BOOTSTRAP_DIR="${ZOLT_BOOTSTRAP_DIR:-build/bootstrap-zolt}"
BOOTSTRAP_JAR="${BOOTSTRAP_DIR}/zolt-bootstrap.jar"
BOOTSTRAP_WORK_ROOT="${BOOTSTRAP_DIR}/work"
LOCKFILE="${ZOLT_LOCKFILE:-zolt.lock}"
MAVEN_CENTRAL="${ZOLT_MAVEN_CENTRAL:-https://repo.maven.apache.org/maven2}"
java_opts=()
if [[ -n "${ZOLT_JAVA_OPTS:-}" ]]; then
  read -r -a java_opts <<< "$ZOLT_JAVA_OPTS"
fi
BOOTSTRAP_LIST_MISSING=false
BOOTSTRAP_OFFLINE=false
if [[ "${ZOLT_BOOTSTRAP_OFFLINE:-}" == "1" ]]; then
  BOOTSTRAP_OFFLINE=true
fi

usage() {
  cat <<'USAGE'
Usage: scripts/bootstrap-zolt-jvm [bootstrap-options] [zolt-args...]

Compiles and runs Zolt from source with JDK tools, zolt.lock, and the local
.zolt/cache artifact cache. Remaining arguments are passed to the Zolt CLI.

Bootstrap options:
  --bootstrap-list-missing   List missing cache artifacts from zolt.lock and exit.
  --bootstrap-offline        Do not download missing bootstrap artifacts.
  --help, -h                 Show this help and exit.

Environment:
  ZOLT_CACHE_ROOT            Artifact cache root. Default: .zolt/cache
  ZOLT_LOCKFILE              Lockfile to read. Default: zolt.lock
  ZOLT_MAVEN_CENTRAL         Download base URL. Default: Maven Central
  ZOLT_BOOTSTRAP_OFFLINE=1   Same as --bootstrap-offline
  ZOLT_JAVA_OPTS             Whitespace-separated JVM options for Zolt.
USAGE
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --bootstrap-list-missing)
      BOOTSTRAP_LIST_MISSING=true
      shift
      ;;
    --bootstrap-offline)
      BOOTSTRAP_OFFLINE=true
      shift
      ;;
    --help | -h)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if [[ ! -f "$LOCKFILE" ]]; then
  printf 'error: bootstrap lockfile does not exist at %s\n' "$LOCKFILE" >&2
  printf 'hint: run zolt resolve before scripts/bootstrap-zolt-jvm\n' >&2
  exit 1
fi

require_jdk_tools() {
  if ! command -v javac >/dev/null 2>&1; then
    printf 'error: javac is required for scripts/bootstrap-zolt-jvm\n' >&2
    printf 'hint: install JDK 21 or set JAVA_HOME to a JDK before retrying\n' >&2
    exit 1
  fi

  if ! command -v jar >/dev/null 2>&1; then
    printf 'error: jar is required for scripts/bootstrap-zolt-jvm\n' >&2
    printf 'hint: install JDK 21 or set JAVA_HOME to a JDK before retrying\n' >&2
    exit 1
  fi
}

if [[ "$BOOTSTRAP_LIST_MISSING" != true && "$BOOTSTRAP_OFFLINE" != true ]]; then
  require_jdk_tools
fi

checksum() {
  if command -v shasum >/dev/null 2>&1; then
    LC_ALL=C LANG=C shasum -a 256 "$1" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    LC_ALL=C LANG=C sha256sum "$1" | awk '{print $1}'
  else
    printf 'error: shasum or sha256sum is required for scripts/bootstrap-zolt-jvm\n' >&2
    exit 1
  fi
}

missing_artifact_block() {
  local coordinate="$1"
  local jar_path="$2"
  local expected_sha="$3"
  local artifact="${CACHE_ROOT}/${jar_path}"

  printf 'missing bootstrap artifact:\n'
  printf '  coordinate: %s\n' "$coordinate"
  printf '  cache: %s\n' "$artifact"
  printf '  source: %s/%s\n' "$MAVEN_CENTRAL" "$jar_path"
  printf '  sha256: %s\n' "$expected_sha"
}

ensure_artifact() {
  local coordinate="$1"
  local jar_path="$2"
  local expected_sha="$3"
  local artifact="${CACHE_ROOT}/${jar_path}"

  if [[ ! -f "$artifact" ]]; then
    if [[ "$BOOTSTRAP_LIST_MISSING" == true || "$BOOTSTRAP_OFFLINE" == true ]]; then
      missing_artifact_block "$coordinate" "$jar_path" "$expected_sha"
      missing_count=$((missing_count + 1))
      return 0
    fi
    if ! command -v curl >/dev/null 2>&1; then
      printf 'error: bootstrap artifact is missing and curl is not available: %s\n' "$artifact" >&2
      missing_artifact_block "$coordinate" "$jar_path" "$expected_sha" >&2
      printf 'hint: seed %s or install curl before scripts/bootstrap-zolt-jvm\n' "$CACHE_ROOT" >&2
      printf 'hint: run scripts/bootstrap-zolt-jvm --bootstrap-list-missing to list missing cache entries\n' >&2
      exit 1
    fi
    mkdir -p "$(dirname "$artifact")"
    if ! curl -fsSL "${MAVEN_CENTRAL}/${jar_path}" -o "$artifact"; then
      rm -f "$artifact"
      printf 'error: could not download bootstrap artifact for %s\n' "$coordinate" >&2
      missing_artifact_block "$coordinate" "$jar_path" "$expected_sha" >&2
      printf 'hint: clean source bootstrap requires Maven Central/network access or a seeded %s cache\n' "$CACHE_ROOT" >&2
      printf 'hint: run scripts/bootstrap-zolt-jvm --bootstrap-list-missing to list cache entries to seed\n' >&2
      exit 1
    fi
  fi

  local actual_sha
  actual_sha="$(checksum "$artifact")"
  if [[ "$actual_sha" != "$expected_sha" ]]; then
    printf 'error: checksum mismatch for bootstrap artifact %s\n' "$artifact" >&2
    printf 'expected: %s\n' "$expected_sha" >&2
    printf 'actual:   %s\n' "$actual_sha" >&2
    printf 'hint: delete the corrupt artifact and rerun scripts/bootstrap-zolt-jvm\n' >&2
    exit 1
  fi
}

classpath=""
missing_count=0
while IFS='|' read -r scope package_id package_version jar_path jar_sha; do
  if [[ -z "$jar_path" ]]; then
    continue
  fi
  coordinate="$package_id"
  if [[ -n "$package_version" ]]; then
    coordinate="${coordinate}:${package_version}"
  fi
  ensure_artifact "$coordinate" "$jar_path" "$jar_sha"
  artifact="${CACHE_ROOT}/${jar_path}"
  [[ -f "$artifact" ]] || continue
  if [[ -z "$classpath" ]]; then
    classpath="$artifact"
  else
    classpath="${classpath}:${artifact}"
  fi
done < <(awk '
  /^\[\[package\]\]/ {
    scope = ""
    id = ""
    version = ""
    jar = ""
    sha = ""
  }
  /^id = / {
    id = $3
    gsub(/"/, "", id)
  }
  /^version = / {
    version = $3
    gsub(/"/, "", version)
  }
  /^scope = / {
    scope = $3
    gsub(/"/, "", scope)
  }
  /^jar = / {
    jar = $3
    gsub(/"/, "", jar)
  }
  /^jarSha256 = / {
    sha = $3
    gsub(/"/, "", sha)
    if (scope != "test") {
      print scope "|" id "|" version "|" jar "|" sha
    }
  }
' "$LOCKFILE")

if [[ "$BOOTSTRAP_LIST_MISSING" == true ]]; then
  if [[ "$missing_count" -gt 0 ]]; then
    printf 'error: %s bootstrap artifact(s) missing from %s\n' "$missing_count" "$CACHE_ROOT" >&2
    printf 'hint: seed the listed cache paths, or rerun scripts/bootstrap-zolt-jvm on a networked machine\n' >&2
    exit 1
  fi
  printf 'ok: all bootstrap artifacts are present in %s\n' "$CACHE_ROOT"
  exit 0
fi

if [[ "$missing_count" -gt 0 ]]; then
  printf 'error: bootstrap offline mode found %s missing artifact(s) in %s\n' "$missing_count" "$CACHE_ROOT" >&2
  printf 'hint: seed the listed cache paths or rerun without --bootstrap-offline on a networked machine\n' >&2
  exit 1
fi

if [[ -z "$classpath" ]]; then
  printf 'error: no compile/runtime bootstrap artifacts were found in %s\n' "$LOCKFILE" >&2
  printf 'hint: check that zolt.lock contains non-test package entries\n' >&2
  exit 1
fi

if [[ "$BOOTSTRAP_OFFLINE" == true ]]; then
  require_jdk_tools
fi

mkdir -p "$BOOTSTRAP_WORK_ROOT"
BOOTSTRAP_WORK_DIR="$(mktemp -d "${BOOTSTRAP_WORK_ROOT}/run.XXXXXX")"
BOOTSTRAP_CLASSES="${BOOTSTRAP_WORK_DIR}/classes"
BOOTSTRAP_RUN_JAR="${BOOTSTRAP_WORK_DIR}/zolt-bootstrap.jar"
BOOTSTRAP_STABLE_JAR_TMP="${BOOTSTRAP_WORK_DIR}/zolt-bootstrap.stable.jar"
SOURCE_LIST="${BOOTSTRAP_WORK_DIR}/sources.list"

cleanup_bootstrap_work() {
  rm -rf "$BOOTSTRAP_WORK_DIR"
}
trap cleanup_bootstrap_work EXIT

case "$BOOTSTRAP_WORK_DIR" in
  "" | "." | "/" | "$ROOT" | "$ROOT"/src | "$ROOT"/src/*)
    printf 'error: refusing unsafe bootstrap work directory: %s\n' "$BOOTSTRAP_WORK_DIR" >&2
    exit 1
    ;;
esac
mkdir -p "$BOOTSTRAP_CLASSES"

source_files=()
collect_java_sources() {
  local source_root="$1"
  local entry

  [[ -d "$source_root" ]] || return 0
  for entry in "$source_root"/*; do
    [[ -e "$entry" ]] || continue
    if [[ -d "$entry" ]]; then
      collect_java_sources "$entry"
    elif [[ "$entry" == *.java ]]; then
      source_files+=("$entry")
    fi
  done
}

for source_root in modules/*/src/main/java apps/*/src/main/java src/main/java; do
  collect_java_sources "$source_root"
done
printf '%s\n' "${source_files[@]}" | sort > "$SOURCE_LIST"

if [[ ! -s "$SOURCE_LIST" ]]; then
  printf 'error: no Java source files found under modules/*/src/main/java or apps/*/src/main/java\n' >&2
  printf 'hint: check the repository layout before scripts/bootstrap-zolt-jvm\n' >&2
  exit 1
fi

javac --release 21 -cp "$classpath" -d "$BOOTSTRAP_CLASSES" @"$SOURCE_LIST"

if [[ -d src/main/resources ]]; then
  cp -R src/main/resources/. "$BOOTSTRAP_CLASSES"/
fi
if [[ -d apps/zolt/src/main/resources ]]; then
  cp -R apps/zolt/src/main/resources/. "$BOOTSTRAP_CLASSES"/
fi

jar --create --file "$BOOTSTRAP_RUN_JAR" --main-class com.zolt.cli.ZoltCli -C "$BOOTSTRAP_CLASSES" .
cp "$BOOTSTRAP_RUN_JAR" "$BOOTSTRAP_STABLE_JAR_TMP"
mv "$BOOTSTRAP_STABLE_JAR_TMP" "$BOOTSTRAP_JAR"

if [[ "${#java_opts[@]}" -gt 0 ]]; then
  java "${java_opts[@]}" -cp "${BOOTSTRAP_RUN_JAR}:${classpath}" com.zolt.cli.ZoltCli "$@"
else
  java -cp "${BOOTSTRAP_RUN_JAR}:${classpath}" com.zolt.cli.ZoltCli "$@"
fi
